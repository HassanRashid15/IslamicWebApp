# React App Configuration
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_APP_NAME=Islamic App
REACT_APP_VERSION=1.0.0

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/islamic-app
MONGODB_DB_NAME=islamic-app
MONGODB_OPTIONS=useNewUrlParser=true&useUnifiedTopology=true

# MongoDB Atlas (for production)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/islamic-app?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development

# API Endpoints
REACT_APP_AUTH_ENDPOINT=/auth
REACT_APP_PROTECTED_ENDPOINT=/protected

# Features
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_ANALYTICS=false

# Theme Configuration
REACT_APP_PRIMARY_COLOR=green
REACT_APP_SECONDARY_COLOR=blue

# IPFind API Configuration
REACT_APP_IPFIND_API_KEY=8a1112c6-c5ba-4bac-9acf-d7a6353583fa