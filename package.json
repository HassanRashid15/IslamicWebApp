{
  "name": "islamic-web-app",
  "version": "1.0.0",
  "description": "Islamic Web App - unified frontend and backend",
  "main": "server.js",
  "private": true,
  "proxy": "http://localhost:5000",
  "scripts": {
    "start": "SET NODE_ENV=production&& node server.js",
    "dev": "concurrently -n server,client -c green,blue \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server.js",
    "dev:client": "SET PORT=3000&& react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "setup": "node setup.js",
    "env": "node scripts/create-env.js",
    "install:all": "npm install"
  },
  "keywords": [
    "islamic",
    "authentication",
    "express",
    "react"
  ],
  "author": "DevStitch",
  "license": "MIT",
  "dependencies": {
    "@testing-library/jest-dom": "^5.14.1",
    "@testing-library/react": "^13.0.0",
    "@testing-library/user-event": "^13.2.1",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "flipping-pages": "^3.1.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "lottie-web": "^5.13.0",
    "mongoose": "^9.2.1",
    "nodemailer": "^6.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-lottie": "^1.2.10",
    "react-router-dom": "^7.6.0",
    "react-scripts": "5.0.1",
    "react-toastify": "^11.0.5",
    "web-vitals": "^2.1.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
